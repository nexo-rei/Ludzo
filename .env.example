# ─── Supabase ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Used for task verification (channel/group membership checks)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=LudzoBot

# ─── Binance Pay ─────────────────────────────────────────────────────────────
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
BINANCE_WEBHOOK_SECRET=your-binance-webhook-secret

# ─── Monetag Ads ─────────────────────────────────────────────────────────────
# Zone ID for rewarded ads — matches show_11113056() function
VITE_MONETAG_ZONE_ID=11113056

# ─── App Config ──────────────────────────────────────────────────────────────
VITE_APP_VERSION=2.0.0
